{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mojolicious",
  "rules": {
    "template": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "content"
          },
          {
            "type": "SYMBOL",
            "name": "block_output_raw"
          },
          {
            "type": "SYMBOL",
            "name": "block_output"
          },
          {
            "type": "SYMBOL",
            "name": "block_code"
          },
          {
            "type": "SYMBOL",
            "name": "block_comment"
          },
          {
            "type": "SYMBOL",
            "name": "line_output_raw"
          },
          {
            "type": "SYMBOL",
            "name": "line_output"
          },
          {
            "type": "SYMBOL",
            "name": "line_code"
          },
          {
            "type": "SYMBOL",
            "name": "line_comment"
          }
        ]
      }
    },
    "block_output_raw": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<%=="
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_block_body"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "%>"
        }
      ]
    },
    "block_output": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<%="
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_block_body"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "%>"
        }
      ]
    },
    "block_code": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<%"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_block_body"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "%>"
        }
      ]
    },
    "block_comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<%#"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_block_body"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "%>"
        }
      ]
    },
    "_block_body": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "([^%]|%[^>])+"
      }
    },
    "line_output_raw": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_line_output_raw_start"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "line_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        }
      ]
    },
    "line_output": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_line_output_start"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "line_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        }
      ]
    },
    "line_code": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_line_code_start"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "line_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        }
      ]
    },
    "line_comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_line_comment_start"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "line_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        }
      ]
    },
    "line_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\r\\n]+"
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "content"
    },
    {
      "type": "SYMBOL",
      "name": "_line_code_start"
    },
    {
      "type": "SYMBOL",
      "name": "_line_output_raw_start"
    },
    {
      "type": "SYMBOL",
      "name": "_line_output_start"
    },
    {
      "type": "SYMBOL",
      "name": "_line_comment_start"
    },
    {
      "type": "SYMBOL",
      "name": "_line_end"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}