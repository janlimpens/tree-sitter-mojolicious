{
  "name": "tree-sitter-mojolicious",
  "version": "0.1.0",
  "description": "Mojolicious (html.ep) grammar for tree-sitter",
  "license": "MIT",
  "main": "bindings/node",
  "tree-sitter": [
    {
      "scope": "text.html.mojolicious",
